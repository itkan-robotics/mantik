# Copy to .env for local submission testing (never commit .env).
#
# PUBLIC_* vars are embedded in the client bundle — not secret.
# Other vars are server-only (Netlify Functions / netlify dev).

# --- Public (browser) — optional locally; dev falls back to Turnstile test site key ---
PUBLIC_TURNSTILE_SITE_KEY=

# --- Secret (server) — required for real GitHub issues locally ---
TURNSTILE_SECRET_KEY=
GITHUB_TOKEN=
GITHUB_REPO=itkan-robotics/mantik

# --- Optional: use Turnstile test secret on Netlify deploy previews (no real Turnstile widget domains) ---
# ALLOW_TURNSTILE_TEST_KEYS=true

# Local with only `npm run dev`: Turnstile widget works (test key); submit needs `npm run dev:netlify`.
# Local with `npm run dev:netlify`: copy this file to .env and set GITHUB_TOKEN (+ optional real Turnstile keys).
