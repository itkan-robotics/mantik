---
interface Props {
  title?: string;
  headers?: string[];
  rows?: string[][];
}

const { title, headers = [], rows = [] } = Astro.props;
---

{title && <h3>{title}</h3>}
<div class="table-container">
  <table class="content-table">
    {headers.length > 0 && (
      <thead>
        <tr>
          {headers.map((header) => <th set:html={header} />)}
        </tr>
      </thead>
    )}
    <tbody>
      {rows.map((row) => (
        <tr>
          {row.map((cell) => <td set:html={cell} />)}
        </tr>
      ))}
    </tbody>
  </table>
</div>
